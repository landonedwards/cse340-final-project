<%- include('../partials/header') %>

<main>
    <h1>Recipe Catalog</h1>
    <p>Browse our entire recipe catalog! It contains submissions from professional chefs and users like you! See one that looks interesting?
       Click on it and see more information, including the steps to make it and the needed ingredients. 
    </p>

    <% if (recipes.length > 0) { %>
        <div class="recipe-list">
            <% recipes.forEach(recipe => { %>
                <div class="recipe-card">
                    <h3><a href="/recipes/<%= recipe.id %>"><%= recipe.title %></a></h3>
                    <p class="recipe-metadata">
                        <%= recipe.authorName %> | Uploaded <%= new Date(recipe.createdAt).toLocaleDateString() %>
                    </p>
                    <p class="recipe-description"><%= recipe.description %></p>
                </div>
            <% }); %>
        </div>
    <% } else { %>
        <p class="missing-recipe-text">No recipes available...</p>
    <% } %>
</main>

<%- include('../partials/footer') %>