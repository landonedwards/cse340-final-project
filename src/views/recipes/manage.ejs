<%- include('../partials/header') %>

<main>
    <h1><%= title %></h1>
    <% if (res.locals.isStaff) { %>
        <p>
           View all of the recipes that have been submitted by users and are awaiting approval. Approve one to send it to
           the public catalog, or reject it and notify the user. 
        </p>

        <% if (pendingRecipes.length > 0) { %>
            <div class="pending-recipe-list">
                <% pendingRecipes.forEach(pendingRecipe => { %>
                    <div class="recipe-card">
                        <h3><a href="/recipes/<%= pendingRecipe.id %>"><%= pendingRecipe.title %></a></h3>
                        <p class="recipe-metadata">
                            <%= pendingRecipe.authorName %> | Uploaded <%= new Date(pendingRecipe.createdAt).toLocaleDateString() %>
                        </p>
                        <p class="recipe-description"><%= pendingRecipe.description %></p>

                        <div class="recipe-actions">
                            <form method="POST" action="/recipes/<%= pendingRecipe.id %>/approve" style="display: inline;">
                                <button type="submit" onclick="return confirm('Are you sure you want to approve this recipe?')">Approve</button>
                            </form>

                            <form method="POST" action="/recipes/<%= pendingRecipe.id %>/reject" style="display: inline;">
                                <button type="submit" onclick="return confirm('Are you sure you want to reject this recipe?')">Reject</button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>

        <h2>Manage My Recipes</h2>
    <% } %>

    <p>
        Manage all of the recipes you've submitted! View, edit, or delete them as needed. 
    </p>

    <% if (recipes.length > 0) { %>
        <div class="recipe-list">
            <% recipes.forEach(recipe => { %>

                <div class="recipe-card">
                    <h3><a href="/recipes/<%= recipe.id %>"><%= recipe.title %></a></h3>
                    <p class="recipe-metadata">
                        <%= recipe.authorName %> | Uploaded <%= new Date(recipe.createdAt).toLocaleDateString() %>
                    </p>
                    <p class="recipe-description"><%= recipe.description %></p>

                    <div class="recipe-actions">
                        <a href="/recipes/<%= recipe.id %>/edit">Edit</a>

                        <form method="POST" action="/recipes/<%= recipe.id %>/delete" style="display: inline;">
                            <button type="submit" onclick="return confirm('Are you sure you want to delete this recipe?')">Delete</button>
                        </form>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } else { %>
        <p class="missing-recipe-text">No recipes available...</p>
    <% } %>
</main>

<%- include('../partials/footer') %>