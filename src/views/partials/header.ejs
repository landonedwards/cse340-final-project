<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body class="<%= locals.bodyClass || '' %>">
    <header>
        <nav>
            <ul>
                <!-- always visible links -->
                <li><a href="/">Home</a></li>
                <li><a href="/recipe/list">Recipe Catalog</a></li>
    
                <!-- only visible when logged in -->
                <% if (locals.isLoggedIn) { %>
                    <!-- dashboard will contain additional links/actions based on your access level -->
                    <li><a href="/dashboard">Dashboard</a></li>
                    <li><a href="/recipe/upload">Submit Recipe</a></li>
                    <li><a href="/logout">Logout</a></li>
                    <% } %>
    
                <!-- only visible when NOT logged in -->
                <% if (!locals.isLoggedIn) { %>
                    <li><a href="/login">Login</a></li>
                    <li><a href="/register">Register</a></li>
                <% } %>
            </ul>
        </nav>
    </header>

